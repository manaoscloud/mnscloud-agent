{
  "tasks": {
    "start": "deno run --allow-read=/etc/mnscloud/agent,/var/lib/mnscloud/agent,/recordings,/media-files --allow-write=/var/lib/mnscloud/agent,/var/log/mnscloud/agent,/recordings,/media-files --allow-net main.ts",
    "check": "deno check main.ts",
    "fmt": "deno fmt"
  },
  "compilerOptions": {
    "strict": true
  }
}
